    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `Order bad in law in the absence of an opportunity for personal '>
  > # end of ParaLine
  <ParaLine 
   <String `hearing'>
   <ElementEnd `Italics'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683377>
  <PgfTag `Quotation2'>
  <ParaLine 
   <ElementBegin 
    <Unique 77298940>
    <ETag `Para3'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `9. The learned Commissioner of Income-tax (Appeals) order in '>
  > # end of ParaLine
  <ParaLine 
   <Font 
    <FTag `'>
    <FDW  -1.0%>
    <FLocked No>
   > # end of Font
   <String `passing the order without providing an opportunity of personal hearing'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` '>
  > # end of ParaLine
  <ParaLine 
   <String `though requested by the appellant.'>
   <ElementEnd `Para3'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683381>
  <PgfTag `Quotation2'>
  <ParaLine 
   <ElementBegin 
    <Unique 77299478>
    <ETag `Para3'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `The appellant prays that the order being passed in violation of '>
  > # end of ParaLine
  <ParaLine 
   <String `principles of natural justice and against the provisions of the '>
   <String `I'>
   <String `ncome-'>
  > # end of ParaLine
  <ParaLine 
   <String `tax Act, 1961 is bad in law and should be quashed.'>
   <ElementEnd `Para3'>
   <ElementEnd `Quote'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683391>
  <PgfTag `s10'>
  <ParaLine 
   <ElementBegin 
    <Unique 78683386>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
