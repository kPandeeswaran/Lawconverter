   <String `55.'>
   <ElementEnd `Bold'>
   <String ` '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `We note that when the assessee mentions the same in its directors’ '>
  > # end of ParaLine
  <ParaLine 
   <String `report, notes on accounts'>
   <String `,'>
   <String ` etc., when the going concern itself hinges on '>
