    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `The assessee challenged the following issues : disallowance of loss on '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `account of assignment of certain receivables and payables to its group '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `concern IA pursuant to valuation and reassessment of its ability to collect '>
  > # end of ParaLine
  <ParaLine 
   <String `such amount ; partial disallowance of interest expenses claimed in excess of '>
  > # end of ParaLine
  <ParaLine 
   <String `interest income earned on inter-corporate deposits ; disallowance of interest '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 56>
   <Font 
    <FTag `'>
    <FDW  -1.0%>
    <FLocked No>
   > # end of Font
   <Char DiscHyphen>
   <String `expenses incurred for the loan taken for investment in EL ; and short-granting'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` '>
  > # end of ParaLine
  <ParaLine 
   <String `of credit for tax deducted at source.'>
