 <ElementDef 
  <EDTag `Judge'>
  <EDObject EDContainer>
  <EDValidHighestLevel No>
  <EDGeneralRule `<TEXT\>'>
  <EDAttrDefinitions 
   <EDAttrDef 
    <EDAttrName `Position'>
    <EDAttrRequired No>
    <EDAttrReadOnly No>
    <EDAttrHidden No>
    <EDAttrType FAttrChoice>
    <EDAttrChoices 
     <EDAttrChoice `JJ.'>
     <EDAttrChoice `C. J. I.'>
     <EDAttrChoice `C. J.'>
     <EDAttrChoice `O .C .J.'>
     <EDAttrChoice `Actg. C. J.'>
     <EDAttrChoice `J.'>
     <EDAttrChoice `None'>
    > # end of EDAttrChoices
    <EDAttrDefValues 
     <EDAttrDefValue `None'>
    > # end of EDAttrDefValues
   > # end of EDAttrDef
  > # end of EDAttrDefinitions
  <EDPgfFormat `'>
  <EDTextFormatRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
     <FormatTag `smallcaps'>
    > # end of If
   > # end of ContextFormatRule
  > # end of EDTextFormatRules
  <EDPrefixRules 
   <ContextFormatRule 
    <If 
     <Context `{after Judge}'>
     <ContextFormatRule 
      <If 
       <Context `{last}'>
       <IsTextRange Yes>
       <ElementPrefix ` and '>
       <FormatTag `zz_normal'>
      > # end of If
      <Else 
       <ElementPrefix `, '>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
   > # end of ContextFormatRule
  > # end of EDPrefixRules
  <EDSuffixRules 
   <ContextFormatRule 
    <If 
     <Context `[Position = "None"]'>
    > # end of If
    <ElseIf 
     <Context `[Position != "None"]'>
     <ElementSuffix ` <$attribute[Position]\>'>
    > # end of ElseIf
   > # end of ContextFormatRule
  > # end of EDSuffixRules
  <EDStartElementRules 
  >
  <EDEndElementRules 
  >
  <EDComments `'>
 > # end of ElementDef
