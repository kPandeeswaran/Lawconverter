   <ElementBegin 
    <Unique 77360882>
    <ETag `Bold'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `26.'>
   <ElementEnd `Bold'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` Though the learned authorised representative did not state in '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `writing in letter dated May 28, 2024 that the assessee does not have a share '>
  > # end of ParaLine
  <ParaLine 
   <String `purchase agreement and therefore it is not available and hence it is not '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 95>
   <String `submitted. However, it was an oral argument of the assessee though the '>
  > # end of ParaLine
  <ParaLine 
   <String `B'>
   <String `ench specifically asked as per the order sheet.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683915>
  <PgfTag `s10'>
  <ParaLine 
   <ElementBegin 
    <Unique 77329366>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Font 
