 <ElementDef 
  <EDTag `CourtName'>
  <EDObject EDContainer>
  <EDValidHighestLevel No>
  <EDGeneralRule `<TEXT\>'>
  <EDPgfFormat `'>
  <EDTextFormatRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
    > # end of If
   > # end of ContextFormatRule
  > # end of EDTextFormatRules
  <EDPrefixRules 
   <ContextFormatRule 
    <If 
     <Context `Court < Case[Special = "Y"]'>
     <IsTextRange Yes>
     <ElementPrefix `[In the Special Court'>
    > # end of If
    <ElseIf 
     <Context `Court < Case[British != "N"]'>
     <ContextFormatRule 
      <If 
       <Context `* < Volume[Series = "Supreme Court Revenue Cases"]'>
      > # end of If
      <Else 
       <ElementPrefix `[\x12 '>
      > # end of Else
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `* < Volume[Series = "Supreme Court Revenue Cases"]'>
    > # end of ElseIf
    <ElseIf 
     <Context `court'>
     <IsTextRange Yes>
     <ElementPrefix `[Before the '>
    > # end of ElseIf
    <Else 
     <IsTextRange Yes>
     <ElementPrefix `[In the '>
    > # end of Else
   > # end of ContextFormatRule
  > # end of EDPrefixRules
  <EDSuffixRules 
   <ContextFormatRule 
    <If 
     <Context `Court < Case[British != "N"]'>
     <ContextFormatRule 
      <If 
       <Context `* < Volume[Series = "Supreme Court Revenue Cases"]'>
      > # end of If
      <Else 
       <ElementSuffix `\x12 ]\x12 '>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
    <ElseIf 
     <Context `Court[SC = "Y"]'>
     <ContextFormatRule 
      <If 
       <Context `* < Volume[Series = "Supreme Court Revenue Cases"]'>
       <ElementSuffix `Supreme Court of India\x12 '>
      > # end of If
      <Else 
       <ElementSuffix `Supreme Court of India\x12 ]'>
      > # end of Else
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `{before Bench}'>
     <ContextFormatRule 
      <If 
       <Context `Court'>
       <ElementSuffix ` High Court'>
      > # end of If
      <ElseIf 
       <Context `court'>
      > # end of ElseIf
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `{before altlocation}'>
     <ContextFormatRule 
      <If 
       <Context `Court'>
       <ElementSuffix ` High Court'>
      > # end of If
      <ElseIf 
       <Context `court'>
      > # end of ElseIf
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `Court < Case[Special = "Y"]'>
     <ElementSuffix `]'>
    > # end of ElseIf
    <Else 
     <ContextFormatRule 
      <If 
       <Context `Court'>
       <ElementSuffix ` High Court]'>
      > # end of If
      <ElseIf 
       <Context `court'>
       <ElementSuffix `]'>
      > # end of ElseIf
     > # end of ContextFormatRule
    > # end of Else
   > # end of ContextFormatRule
  > # end of EDSuffixRules
  <EDStartElementRules 
  >
  <EDEndElementRules 
  >
  <EDComments `'>
 > # end of ElementDef
