 <ElementDef 
  <EDTag `Hf'>
  <EDObject EDContainer>
  <EDValidHighestLevel No>
  <EDGeneralRule `<EMPTY\>'>
  <EDAttrDefinitions 
   <EDAttrDef 
    <EDAttrName `Favourof'>
    <EDAttrRequired Yes>
    <EDAttrReadOnly No>
    <EDAttrHidden No>
    <EDAttrType FAttrChoice>
    <EDAttrChoices 
     <EDAttrChoice `Assessee'>
     <EDAttrChoice `Appellant'>
     <EDAttrChoice `Department'>
     <EDAttrChoice `Remanded'>
     <EDAttrChoice `Matter referred to larger Bench'>
     <EDAttrChoice `Referred to Appropriate Bench'>
     <EDAttrChoice `Referred to Third Judge'>
     <EDAttrChoice `Petitioner'>
     <EDAttrChoice `Respondent'>
     <EDAttrChoice `Observations'>
     <EDAttrChoice `Directions'>
     <EDAttrChoice `Clarification'>
     <EDAttrChoice `Plaintiff'>
     <EDAttrChoice `Applicant'>
     <EDAttrChoice `Dismissed'>
     <EDAttrChoice `Rejected'>
     <EDAttrChoice `Defendant'>
     <EDAttrChoice `Noticee'>
    > # end of EDAttrChoices
   > # end of EDAttrDef
  > # end of EDAttrDefinitions
  <EDPgfFormat `'>
  <EDTextFormatRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
    > # end of If
   > # end of ContextFormatRule
  > # end of EDTextFormatRules
  <EDPrefixRules 
  >
  <EDSuffixRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
     <ElementSuffix `<$attribute[Favourof]\>'>
    > # end of If
   > # end of ContextFormatRule
   <ContextFormatRule 
    <If 
     <Context `* < HFGroup'>
     <ContextFormatRule 
      <If 
       <Context `{before Hf}'>
       <ElementSuffix `<$attribute[Favourof]\>\x12 /\x12 '>
      > # end of If
      <Else 
       <ElementSuffix `<$attribute[Favourof]\>'>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
   > # end of ContextFormatRule
  > # end of EDSuffixRules
  <EDStartElementRules 
  >
  <EDEndElementRules 
  >
  <EDComments `6/24/06: Added the following extra attrib. choices to Hf (remanded)7/21/06: To provide for these additional attrib. choices (assessee/remanded. department/remanded, assessee/deparment/remanded, we decided to do away with the comma and use only front slash as a separator. The attrib. choice Assessee/Deparment is being removed as this will be handled by formatting henceforth) 1/10/13: Added attribute: "Matter Referred to Larger Bench, Petitioner, Respondent, Observations, Directions"12/9/13: Added attribute choice "appellant" as per problem here.2/11/18: Added attribute choices "Plaintiff, Applicant, Dismissed, Rejected" 2/8/2022: Added attribute choices "Referred to Appropriate Bench" and "Referred to Third Judge" <click here\> 13/2/2024: Added attribute choices "Defendant" <click here\>12-Feb-2025: Added attribute choice "Noticee". <Click here\>'>
 > # end of ElementDef
