   <String `caring values of the investment and the dues aggregating to '>
  > # end of ParaLine
  <ParaLine 
   <String `Rs.'>
   <Char EnSpace>
   <String `3'>
   <String `,'>
   <String `613.44 crore'>
   <String `s'>
   <String ` as of March 31, 2017 or debit to the statement of '>
  > # end of ParaLine
  <ParaLine 
   <String `profit and loss of Rs. 177.50 crore'>
   <String `s'>
   <String ` for the year.”'>
