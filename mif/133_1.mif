  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78695241>
  <PgfTag `Quotation1'>
  <Pgf 
   <PgfPlacement PageTop>
  > # end of Pgf
  <ParaLine 
   <TextRectID 140>
   <ElementBegin 
    <Unique 77266319>
    <ETag `Para2'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `8. Though the Revenue has raised a number of issues on the merits '>
  > # end of ParaLine
  <ParaLine 
   <String `in its appeal, but we have quashed the reassessment order, therefore, '>
  > # end of ParaLine
  <ParaLine 
   <String `all the issues become academic in nature at this stage. We have '>
  > # end of ParaLine
  <ParaLine 
   <String `quashed the assessment order on the strength of number of '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `judgments rendered by the hon’ble jurisdictional High Court, which '>
  > # end of ParaLine
  <ParaLine 
   <String `is a view unanimously taken by other hon’ble High Courts also. '>
  > # end of ParaLine
  <ParaLine 
   <String `Therefore, we do not deem it necessary to consider other issues on '>
  > # end of ParaLine
  <ParaLine 
   <String `the merits.”'>
   <ElementEnd `Para2'>
   <ElementEnd `Quote'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78695249>
  <PgfTag `s10'>
  <ParaLine 
