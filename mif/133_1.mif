   > # end of ElementBegin
   <String `25.'>
   <ElementEnd `Bold'>
   <String ` '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `The '>
   <String `learned authorised representative categorically submitted that '>
  > # end of ParaLine
  <ParaLine 
   <String `the '>
   <String `assessee does not have a share purchase agreement and so it is not '>
  > # end of ParaLine
  <ParaLine 
   <String `available and hence not furnished. It stated that such share purchase '>
  > # end of ParaLine
  <ParaLine 
   <String `agreement is between Essar group of company with the buyer. The '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `assessee does not have any access to such agreement and therefore it is not '>
  > # end of ParaLine
  <ParaLine 
   <String `submitted.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683908>
  <PgfTag `s10'>
  <ParaLine 
   <ElementBegin 
    <Unique 77329058>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Font 
    <FTag `Bold'>
    <FLocked No>
