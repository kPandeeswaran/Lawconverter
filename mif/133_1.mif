    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `4.4 Vide submissions dated December 11, 2019 the assessee has '>
  > # end of ParaLine
  <ParaLine 
   <String `provided the following explanation :'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
