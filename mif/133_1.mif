 <Para 
  <Unique 78684342>
  <PgfTag `s10'>
  <ParaLine 
   <ElementBegin 
    <Unique 77343373>
    <ETag `Para'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <Font 
