    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `”Resolved that in accordance with the provisions of the Companies '>
  > # end of ParaLine
  <ParaLine 
   <String `Act, 2013 (Act) read with rule frame thereunder, as may be amended '>
  > # end of ParaLine
  <ParaLine 
   <String `from time-to-time and memorandum and articles of association of '>
  > # end of ParaLine
  <ParaLine 
   <String `the company, and subject to all other applicable laws, the board '>
  > # end of ParaLine
  <ParaLine 
   <String `hereby approves assignment of all the receivables from domestic '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 109>
   <String `group companies to move the company had extended into corporate '>
  > # end of ParaLine
  <ParaLine 
   <String `deposits from time'>
   <String `-'>
   <String `to'>
   <String `-'>
   <String `time and simultaneous assignment of related '>
