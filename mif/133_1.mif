   <String `70.'>
   <ElementEnd `Bold'>
   <String ` '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `Ground Nos. 6-7 is with respect to the disallowance of interest '>
  > # end of ParaLine
  <ParaLine 
   <String `expenses incurred for the loan used for investment in Ennegaon Ltd., '>
