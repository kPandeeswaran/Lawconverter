 <Para 
  <Unique 78683624>
  <PgfTag `Quotation2'>
  <ParaLine 
   <TextRectID 78>
   <ElementBegin 
    <Unique 77314143>
    <ETag `Para3'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `In the case of the company, the loss of assignment'>
   <String `,'>
   <String ` inter alia'>
   <String `,'>
   <String ` '>
  > # end of ParaLine
  <ParaLine 
   <String `includes ICDs and interest on ICDs. The interest on ICDs have been '>
  > # end of ParaLine
  <ParaLine 
   <String `offered to tax as business income in previous years. Consequently, '>
  > # end of ParaLine
  <ParaLine 
   <String `based on the provisions of the law and fact of our case, this amount is '>
  > # end of ParaLine
  <ParaLine 
   <String `clearly allowable as a deduction.’'>
   <ElementEnd `Para3'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683628>
  <PgfTag `Quotation1'>
  <ParaLine 
   <ElementBegin 
    <Unique 77314584>
    <ETag `Para2'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `4.5.2 The submissions made by the assessee in relation to loss on '>
  > # end of ParaLine
  <ParaLine 
   <String `transfer of ICDs and interest thereon have been perused. As per the '>
  > # end of ParaLine
  <ParaLine 
   <String `assessee’s own submissions vide submissions dated September 12, '>
  > # end of ParaLine
  <ParaLine 
   <String `2019, the assessee’s business is that of integrated oil terminal situated '>
  > # end of ParaLine
  <ParaLine 
   <String `at Vadinar, Gujarat.'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683632>
  <PgfTag `Quotation1'>
  <ParaLine 
   <ElementBegin 
    <Unique 77315022>
    <ETag `Para2'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `It has a capacity of 58 MMTPA and handles crude oil and petro'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `leum products. These facilities cater to provide services only to '>
  > # end of ParaLine
  <ParaLine 
   <String `Nayara Energy Ltd. (formerly known as Essar '>
   <String `O'>
   <String `il Ltd.).'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683636>
  <PgfTag `Quotation1'>
  <ParaLine 
   <ElementBegin 
    <Unique 77315457>
    <ETag `Para2'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `4.5.3 The assessee is taking refuge only on the thin ground that in '>
  > # end of ParaLine
  <ParaLine 
   <String `earlier year it has recognised interest income as business income. '>
  > # end of ParaLine
  <ParaLine 
   <String `Hence'>
   <String `,'>
   <String ` it may be construed to be in money lending business. The '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `surmise of the assessee is not acceptable. To put things in perspective '>
  > # end of ParaLine
  <ParaLine 
   <String `the following facts should be noted :'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683640>
  <PgfTag `Quotation2'>
  <ParaLine 
   <ElementBegin 
    <Unique 77315889>
    <ETag `Para3'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `1. The assessee-Vadinar Ports and Terminals Ltd (VPTL) and '>
  > # end of ParaLine
  <ParaLine 
   <String `Vadinar Oil Terminal Ltd. (VOTL) has received inter'>
   <String `-'>
   <String `corporate '>
  > # end of ParaLine
  <ParaLine 
   <String `deposits (ICD) from Essar'>
   <String ` '>
   <String `O'>
   <String `il and Essar '>
   <String `P'>
   <String `orts Ltd. in earlier years. '>
  > # end of ParaLine
  <ParaLine 
   <String `The funds out of these ICDs are advanced as ICDs to Essar group '>
  > # end of ParaLine
  <ParaLine 
   <String `companies, which are shareholder or subsidiaries of Essar '>
   <String `O'>
   <String `il.'>
   <ElementEnd `Para3'>
  > # end of ParaLine
 > # end of Para
