    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `”4.1 During the year under consideration the assessee has declared '>
  > # end of ParaLine
  <ParaLine 
   <String `earnings before exceptional items and tax at Rs. 347.5 crores. The '>
  > # end of ParaLine
  <ParaLine 
   <String `assessee has claimed Rs. 918.68 crores as exceptional items due to '>
  > # end of ParaLine
  <ParaLine 
   <String `which its profit before tax shrinks to a loss of Rs. 570.83 crores.'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683539>
  <PgfTag `Quotation1'>
  <ParaLine 
   <ElementBegin 
