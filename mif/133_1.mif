   <ElementEnd `CRTo'>
   <ElementEnd `Reference'>
   <FNote 1632>
   <String ` (I. T. A. No. 1040/Chand/2024 and C. '>
  > # end of ParaLine
  <ParaLine 
   <String `O. No. 41/Chand/2024, dated May 13, 2025), wherein the '>
   <String `c'>
   <String `o-ordinate '>
  > # end of ParaLine
  <ParaLine 
   <String `Bench following the decision of hon’ble Punjab and Haryana High Court '>
  > # end of ParaLine
  <ParaLine 
   <String `has held that the notice issued under section 148 is bad in the eyes of law. '>
  > # end of ParaLine
  <ParaLine 
   <String `In this regard, the relevant finding of the '>
   <String `c'>
   <String `o-ordinate Bench read as under :'>
   <ElementEnd `Para'>
  > # end of ParaLine
