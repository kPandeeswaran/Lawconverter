   > # end of XRef
   <Font 
    <FTag `Super'>
    <FLocked No>
   > # end of Font
   <String `1'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <XRefEnd >
   <String ` has referred to the decision of the hon’ble jurisdictional '>
  > # end of ParaLine
  <ParaLine 
   <String `High Court wherein the notice issued by the jurisdictional Assessing '>
  > # end of ParaLine
  <ParaLine 
   <String `Officer has been quashed by the hon’ble Punjab and Haryana High Court '>
  > # end of ParaLine
  <ParaLine 
   <String `and by following the same, it has been held that the notice so issued is bad '>
  > # end of ParaLine
  <ParaLine 
   <String `in law. Nothing has been brought on record to deviate from the view so '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 142>
   <String `taken by the '>
   <String `c'>
   <String `o-ordinate Benches which in turn '>
   <String `are'>
   <String ` guided by the decision '>
  > # end of ParaLine
  <ParaLine 
   <String `of the hon’ble jurisdictional High Court. Respectfully following the '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `decision of hon’ble jurisdictional High Court which has been followed by '>
  > # end of ParaLine
  <ParaLine 
   <String `the '>
   <String `c'>
   <String `o-ordinate Benches in '>
   <String `the '>
   <String `decisions referred supra, the notice so '>
  > # end of ParaLine
  <ParaLine 
   <String `issued on March 30, 2023 by the jurisdictional Assessing Officer, i. e., '>
  > # end of ParaLine
  <ParaLine 
   <String `Income-tax Officer, Ward Nabha is clearly without jurisdiction and bad in '>
  > # end of ParaLine
  <ParaLine 
   <String `law. In light of the same, the additional ground of appeal so taken by the '>
  > # end of ParaLine
  <ParaLine 
   <String `assessee is hereby allowed.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
