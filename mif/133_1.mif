    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `Section 36(1)(vii) of the '>
   <String `A'>
   <String `ct provides that subject to the provi'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `sions of section 36(2) of the '>
   <String `A'>
   <String `ct, the amount of bad debt which is '>
  > # end of ParaLine
  <ParaLine 
   <String `written off as irrecoverable in the accounts of the assessee shall be '>
  > # end of ParaLine
  <ParaLine 
   <String `allowed as a deduction in computing business income. Further, '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `section 36(2) of the '>
   <String `A'>
   <String `ct provides the condition for claiming deduction '>
  > # end of ParaLine
  <ParaLine 
   <String `under section 36(1) of the '>
   <String `A'>
   <String `ct, inter alia'>
   <String `,'>
   <String ` including'>
   <String ` :'>
