    <ETag `Para2'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `4.3 Item 40(a) to the notes deals with the ‘'>
   <String `d'>
   <String `ebit to profit or loss on '>
  > # end of ParaLine
  <ParaLine 
   <String `reassessment of the company’s ability to collect the amount specified '>
  > # end of ParaLine
  <ParaLine 
   <String `in note 56. The amount debited towards this head is Rs. 177.50 crores. '>
  > # end of ParaLine
  <ParaLine 
   <String `It is further seen that this amount has not been added back to the '>
  > # end of ParaLine
  <ParaLine 
   <String `total income of the assessee. The assessee was show caused to explain '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 76>
   <String `why such amount should not be added back to the total income of '>
  > # end of ParaLine
  <ParaLine 
   <String `the assessee.'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
