    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `77.'>
   <ElementEnd `Bold'>
   <String ` '>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String `Ground No. 8 is with respect to non-granting of the tax deduction at '>
  > # end of ParaLine
  <ParaLine 
   <String `source credit of Rs. 229 lakhs. Both the parties agreed that this is an issue of '>
  > # end of ParaLine
  <ParaLine 
   <String `credit of tax deduction at source to the assessee which may be verified by '>
  > # end of ParaLine
  <ParaLine 
   <String `the learned Assessing Officer. In view of this, we direct the assessee to '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `substantiate its claim of the above credit before the learned Assessing '>
  > # end of ParaLine
  <ParaLine 
   <String `Officer who may decide the issue after verification on its own merits. '>
  > # end of ParaLine
  <ParaLine 
   <String `Accordingly ground No. 8 of the appeal of the assessee is allowed with '>
  > # end of ParaLine
  <ParaLine 
   <String `above direction.'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
