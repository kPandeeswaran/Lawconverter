    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `‘1. Challenge made through the instant petition is to the notice '>
  > # end of ParaLine
  <ParaLine 
   <String `dated March 1, 2025 (annexure P'>
   <String `1'>
   <String `) issued to the petitioner by the '>
  > # end of ParaLine
  <ParaLine 
   <String `respondents '>
   <String `u'>
   <String `nder section 148 of the Income-tax Act, 1961. The pri'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `mary ground of challenge raised by the petitioner is that the '>
  > # end of ParaLine
  <ParaLine 
   <String `impugned notice has been issued by the '>
   <String `j'>
   <String `urisdictional Assessing '>
  > # end of ParaLine
  <ParaLine 
   <String `Officer which could not have been done because in terms of the noti'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `fication dated March 29, 2022 (annexure P2), issued by the Ministry of '>
  > # end of ParaLine
  <ParaLine 
   <String `Finance'>
   <String `,'>
   <String ` Government of India, the impugned notice could have been '>
  > # end of ParaLine
  <ParaLine 
   <String `issued only by way of faceless assessment.'>
   <ElementEnd `Para3'>
  > # end of ParaLine
 > # end of Para
