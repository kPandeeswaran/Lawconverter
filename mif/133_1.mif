    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `4.2 '>
   <String `I'>
   <String `t is seen from the notes to accounts, item 40 deals with the '>
  > # end of ParaLine
  <ParaLine 
   <String `exceptional items. The assessee was asked to provide details of such '>
  > # end of ParaLine
  <ParaLine 
   <String `expenses vide notice under section 142(1), dated November 11, 2019. '>
  > # end of ParaLine
  <ParaLine 
   <String `Vide its submissions dated December 6, 2019, the assessee has '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `provided details of such expenses claimed in the profit and loss '>
  > # end of ParaLine
  <ParaLine 
   <String `account.'>
   <ElementEnd `Para2'>
  > # end of ParaLine
 > # end of Para
 <Para 
  <Unique 78683543>
