    <ETag `Bold'>
    <Attributes 
    > # end of Attributes
    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `16.'>
   <ElementEnd `Bold'>
   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` Thus the learned Assessing Officer held that it is a sham transaction '>
  > # end of ParaLine
  <ParaLine 
   <String `and loss is '>
   <String `fictitious'>
   <String `, it is not allowable as bad debt and not allowable as '>
  > # end of ParaLine
  <ParaLine 
   <String `business loss.'>
   <ElementEnd `Para'>
  > # end of ParaLine
