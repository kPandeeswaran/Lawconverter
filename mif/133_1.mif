    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `“Notwithstanding the original grounds of appeal, the reassessment '>
  > # end of ParaLine
  <ParaLine 
   <String `proceedings initiated under section 148 of the Income-tax Act, 1961 '>
  > # end of ParaLine
  <ParaLine 
   <String `are bad in law and void ab initio, as the notice under section 148 was '>
  > # end of ParaLine
  <ParaLine 
   <String `issued by the jurisdictional Assessing Officer (JAO) instead of the '>
  > # end of ParaLine
  <ParaLine 
   <String `National Faceless Assessment Centre (NFAC), which is in violation of '>
  > # end of ParaLine
  <ParaLine 
   <String `the mandatory procedure prescribed under sections 144B and 151A of '>
  > # end of ParaLine
  <ParaLine 
   <String `the Act, vide notification Central Board of Direct Taxes Notification '>
  > # end of ParaLine
  <ParaLine 
   <String `No. 18/2022/F. No. 370142/16/2022-TPL '>
   <String `('>
   <String `Part'>
   <String ` '>
   <String `1'>
   <String `)'>
   <String ` dated March 29, '>
  > # end of ParaLine
  <ParaLine 
   <String `2022 '>
   <String `([2022] 442 ITR (St.) 198) '>
   <String `and as clarified by the hon’ble Punjab '>
  > # end of ParaLine
  <ParaLine 
   <String `and Haryana High Court in the case of '>
