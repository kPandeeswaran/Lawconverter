    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `After due consideration, the company sold the portfolio of out'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `standing receivables amounting to Rs. 2'>
   <String `,'>
   <String `569.42 crore'>
   <String `s'>
   <String ` and payable '>
  > # end of ParaLine
  <ParaLine 
   <String `amounting to Rs. 2'>
   <String `,'>
   <String `298.21 crore'>
   <String `s'>
   <String ` from certain related parties and '>
  > # end of ParaLine
  <ParaLine 
   <String `other entities to '>
   <String `Essar'>
   <String ` '>
   <String `St'>
   <String `eels '>
   <String `Jharkhand'>
   <String ` Ltd. and Ibrox '>
   <String `A'>
   <String `viation and '>
  > # end of ParaLine
  <ParaLine 
   <String `T'>
   <String `rading P. Ltd., at fair valuation. On the basis of fair valuation of '>
  > # end of ParaLine
  <ParaLine 
   <String `these outstanding receivables and payables, the company has debited '>
  > # end of ParaLine
  <ParaLine 
   <String `to profit and loss Rs. 177.50 crores as an exceptional item. The '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `company expects to realise the caring values of the investment and '>
  > # end of ParaLine
  <ParaLine 
   <String `other dues through the escrow arrangement shortly.”'>
