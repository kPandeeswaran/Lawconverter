     <EDAttrChoice `Technical Members'>
     <EDAttrChoice `Revenue Member'>
     <EDAttrChoice `Revenue Members'>
     <EDAttrChoice `Member Law'>
     <EDAttrChoice `Member Revenue'>
     <EDAttrChoice `Member Accountant'>
