  > # end of ParaLine
  <ParaLine 
   <String `the books of account, not allowable as deduction as a bad debt and as a '>
  > # end of ParaLine
  <ParaLine 
   <String `business loss which is also confirmed by the learned Commissioner of '>
  > # end of ParaLine
  <ParaLine 
   <String `Income-tax (Appeals).'>
   <ElementEnd `Para'>
  > # end of ParaLine
 > # end of Para
