   <Font 
    <FTag `'>
    <FLocked No>
   > # end of Font
   <String ` When '>
   <String `the '>
   <String `assessee has not produced such agreement which is called '>
  > # end of ParaLine
  <ParaLine 
   <String `for by the '>
   <String `B'>
   <String `ench, auditors of the company have qualified the report on this '>
  > # end of ParaLine
  <ParaLine 
   <String `issue itself ('>
   <String `w'>
   <String `rite off exceptional item of Rs. 177.5 crores), going concern of '>
  > # end of ParaLine
  <ParaLine 
   <String `the assessee itself depends on such agreement, and fact mentioned above, '>
  > # end of ParaLine
  <ParaLine 
   <String `we do not find any reason to deviate from the orders of the learned lower '>
  > # end of ParaLine
