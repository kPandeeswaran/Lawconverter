    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `2. That for many years interest payments against ICD were '>
  > # end of ParaLine
  <ParaLine 
   <String `accrued but not paid and stood in the books as payable.'>
