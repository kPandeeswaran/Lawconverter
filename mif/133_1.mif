   <EDAttrDef 
    <EDAttrName `Position2'>
    <EDAttrRequired No>
    <EDAttrReadOnly No>
    <EDAttrHidden No>
    <EDAttrType FAttrChoice>
    <EDAttrChoices 
     <EDAttrChoice `President'>
     <EDAttrChoice `Senior Vice-President'>
     <EDAttrChoice `Vice Presidents'>
     <EDAttrChoice `Senior Vice President'>
     <EDAttrChoice `Vice President'>
