   <Char EnSpace>
   <String `1'>
   <String `,'>
   <String `599 crores were transferred whereas in case of Ibrox '>
   <String `A'>
   <String `viation and '>
  > # end of ParaLine
  <ParaLine 
   <TextRectID 107>
   <String `T'>
   <String `rading P. Ltd. the liability of Rs. 699.29 crores were transferred.'>
   <String ` '>
   <String `It is to be '>
