  <EDPgfFormat `'>
  <EDTextFormatRules 
   <ContextFormatRule 
    <If 
     <Context `'>
     <FmtChangeList 
      <FCase FSmallCaps>
     > # end of FmtChangeList
    > # end of If
   > # end of ContextFormatRule
   <ContextFormatRule 
    <If 
     <Context `'>
     <IsTextRange Yes>
    > # end of If
   > # end of ContextFormatRule
  > # end of EDTextFormatRules
  <EDPrefixRules 
   <ContextFormatRule 
    <If 
     <Context `{after TJudge}'>
     <ContextFormatRule 
      <If 
       <Context `{last}'>
       <IsTextRange Yes>
       <ElementPrefix ` and '>
       <FormatTag `zz_normal'>
      > # end of If
      <Else 
       <ElementPrefix `, '>
      > # end of Else
     > # end of ContextFormatRule
    > # end of If
   > # end of ContextFormatRule
  > # end of EDPrefixRules
  <EDSuffixRules 
   <ContextFormatRule 
    <If 
     <Context `[Position1 = "None"]'>
     <ContextFormatRule 
      <If 
       <Context `[Position2 != "None"]'>
       <IsTextRange Yes>
       <ElementSuffix ` (ERROR: ATTRIBUTE: POSITION1 SHOULD NOT BE EMPTY)'>
       <FmtChangeList 
        <FAngle `Italic'>
        <FCase FAsTyped>
        <FColor `Red'>
       > # end of FmtChangeList
      > # end of If
     > # end of ContextFormatRule
    > # end of If
    <ElseIf 
     <Context `[Position2 = "None"]'>
     <ContextFormatRule 
      <If 
       <Context `[Position1 != "None"]'>
       <ContextFormatRule 
        <If 
         <Context `[Position1 = "J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\>'>
        > # end of If
        <ElseIf 
         <Context `[Position1 = "J-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>J. (Retd.)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "JJ."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "JJ-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>JJ. (Retd)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "C. J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "CJ-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>C. J. (Retd.)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "C. J. I."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "CJI-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>C. J. I. (Retd.)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "Actg. C. J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\>'>
        > # end of ElseIf
        <Else 
         <IsTextRange Yes>
         <ElementSuffix ` <semibolditalics\>(<$attribute[Position1]\>)<Default Para Font\>'>
        > # end of Else
       > # end of ContextFormatRule
      > # end of If
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `[Position1 = "None"]'>
     <ContextFormatRule 
      <If 
       <Context `[Position2 = "None"]'>
      > # end of If
     > # end of ContextFormatRule
    > # end of ElseIf
    <ElseIf 
     <Context `[Position1 != "None"]'>
     <ContextFormatRule 
      <If 
       <Context `[Position2 != "None"]'>
       <ContextFormatRule 
        <If 
         <Context `[Position1 = "J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\> <semibolditalics\>(<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of If
        <ElseIf 
         <Context `[Position1 = "J-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>J. (Retd.)<Default Para Font\> <semibolditalics\>(<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "JJ."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "JJ-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>JJ. (Retd) <Default Para Font\><semibolditalics\>(<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "C. J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "CJ-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>C. J. (Retd.)<Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "C. J. I."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "CJI-Retd"]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\>C. J. I. (Retd.)<Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <ElseIf 
         <Context `[Position1 = "Actg. C. J."]'>
         <IsTextRange Yes>
         <ElementSuffix ` <smallcaps\><$attribute[Position1]\><Default Para Font\> <semibolditalics\> (<$attribute[Position2]\>)<Default Para Font\>'>
        > # end of ElseIf
        <Else 
         <IsTextRange Yes>
         <ElementSuffix ` <semibolditalics\>(<$attribute[Position1]\>) (<$attribute[Position2]\>)'>
        > # end of Else
       > # end of ContextFormatRule
      > # end of If
     > # end of ContextFormatRule
    > # end of ElseIf
   > # end of ContextFormatRule
  > # end of EDSuffixRules
