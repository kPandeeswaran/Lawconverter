    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `‘Pursuant to the agreement between the company and Ibrox '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `Aviation and Trading P. Ltd. (IAPL) certain identified assets and '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
   <String `liabilities comprising of ICDs, security deposits, other receivables, '>
  > # end of ParaLine
  <ParaLine 
   <String `interest on ICDs and payables from/to the Essar group were assigned '>
  > # end of ParaLine
  <ParaLine 
   <String `to Ibrox Aviation and Trading P. Ltd. In view of the same, VOTL '>
  > # end of ParaLine
  <ParaLine 
   <String `received an amount of Rs. 4.79 crores from IAPL as a consideration '>
  > # end of ParaLine
  <ParaLine 
   <String `for transfer of net value of identified assets and liability ('>
   <String `c'>
   <String `opy of '>
  > # end of ParaLine
  <ParaLine 
   <String `agreement attached herewith).'>
