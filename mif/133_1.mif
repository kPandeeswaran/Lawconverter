    <Collapsed No>
    <SpecialCase No>
    <AttributeDisplay AllAttributes>
   > # end of ElementBegin
   <String `Attention is invited to note No. 56 regarding the ability of the com'>
   <Char SoftHyphen>
  > # end of ParaLine
  <ParaLine 
   <String `pany to realise investment in a subsidiary company and amounts due '>
  > # end of ParaLine
  <ParaLine 
   <String `from certain related parties, which is predicated on successful closure '>
  > # end of ParaLine
  <ParaLine 
   <String `of the sale of shares by the majority shareholders of Essar '>
   <String `O'>
   <String `il Ltd., '>
  > # end of ParaLine
  <ParaLine 
   <String `The holding company and application of the sales consideration '>
  > # end of ParaLine
  <ParaLine 
   <String `towards the discharge of the aforesaid amounts, as explained in the '>
  > # end of ParaLine
  <ParaLine 
   <String `note. In view of the delay in achieving closure of the sale transaction '>
  > # end of ParaLine
  <ParaLine 
   <String `and the consequent collection of the amounts as envisaged, and '>
  > # end of ParaLine
  <ParaLine 
   <Char DiscHyphen>
